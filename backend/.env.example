# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# Comma-separated list of allowed frontend origins
# e.g. http://localhost:5173,https://myapp.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Supabase Database (PostgreSQL) ────────────────────────────────────────────
# Direct connection (port 5432) — fine for persistent servers.
# For serverless environments (Vercel Functions, AWS Lambda, etc.), use the
# connection pooler URL (port 6543) to avoid exhausting database connections:
#   postgresql://postgres:[PASSWORD]@db.[REF].pooler.supabase.co:6543/postgres
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ── Supabase API (for Storage, Auth, etc.) ────────────────────────────────────
# Project URL — get from Supabase → Settings → API
SUPABASE_URL=https://[PROJECT-REF].supabase.co

# service_role key — server-side ONLY. Never expose to client code.
# Get from: Supabase → Settings → API → Project API keys
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# anon/public key — safe for client-side use (protected by RLS).
# Only needed if you add Supabase Auth or client-side SDK calls.
# SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
